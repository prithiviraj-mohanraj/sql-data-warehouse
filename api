import pandas as pd

scope = pd.read_csv("scope_summary.csv")
cloudera_columns = pd.read_csv("table_columns.csv")

scope = scope.apply(lambda c: c.str.lower() if c.dtype=="object" else c)
cloudera_columns = cloudera_columns.apply(lambda c: c.str.lower() if c.dtype=="object" else c)

schemas = scope['schema'].unique().tolist()

sf_tables_list = []

for schema in schemas:
    try:
        df = session.sql(f"SHOW TABLES IN SCHEMA prod.{schema}").to_pandas()
        df['schema'] = schema
        sf_tables_list.append(df[['schema','name']])
    except:
        pass

sf_tables = pd.concat(sf_tables_list, ignore_index=True)
sf_tables.rename(columns={'name':'table'}, inplace=True)
sf_tables['table'] = sf_tables['table'].str.lower()

table_compare = scope.merge(
    sf_tables,
    on=['schema','table'],
    how='left',
    indicator=True
)

table_compare['exists_in_snowflake'] = table_compare['_merge'] == 'both'
table_compare = table_compare[['schema','table','exists_in_snowflake']]


cloudera_counts = scope.groupby('schema').size().reset_index(name='cloudera_table_count')



sf_counts = table_compare[table_compare['exists_in_snowflake']] \
    .groupby('schema').size().reset_index(name='snowflake_table_count')

schema_summary = cloudera_counts.merge(sf_counts, on='schema', how='left').fillna(0)
schema_summary['missing_tables'] = schema_summary['cloudera_table_count'] - schema_summary['snowflake_table_count']

schema_summary
sf_columns_list = []

for _, row in table_compare.iterrows():
    if row['exists_in_snowflake']:
        schema = row['schema']
        table = row['table']
        try:
            df = session.sql(f"SHOW COLUMNS IN TABLE prod.{schema}.{table}").to_pandas()
            df['schema'] = schema
            df['table'] = table
            sf_columns_list.append(df[['schema','table','column_name']])
        except:
            pass

sf_columns = pd.concat(sf_columns_list, ignore_index=True)
sf_columns.rename(columns={'column_name':'column'}, inplace=True)
sf_columns = sf_columns.apply(lambda c: c.str.lower() if c.dtype=="object" else c)

cloudera_col_counts = cloudera_columns.groupby(['schema','table']).size().reset_index(name='cloudera_column_count')
sf_col_counts = sf_columns.groupby(['schema','table']).size().reset_index(name='snowflake_column_count')

column_summary = table_compare.merge(cloudera_col_counts, on=['schema','table'], how='left') \
    .merge(sf_col_counts, on=['schema','table'], how='left')

column_summary['snowflake_column_count'] = column_summary['snowflake_column_count'].fillna(0)
column_summary['column_mismatch'] = column_summary['cloudera_column_count'] != column_summary['snowflake_column_count']

column_summary

missing_columns = cloudera_columns.merge(
    sf_columns,
    on=['schema','table','column'],
    how='left',
    indicator=True
)

missing_columns = missing_columns[missing_columns['_merge'] == 'left_only']
missing_columns = missing_columns[['schema','table','column']]

missing_columns
