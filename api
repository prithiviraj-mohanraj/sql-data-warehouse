import pandas as pd

schemas = pd.read_csv("schemas.txt", header=None, names=["schema"])
cloudera_tables = pd.read_csv("cloudera_tables.csv")
cloudera_columns = pd.read_csv("cloudera_columns.csv")


sf_schemas = session.sql("SHOW SCHEMAS").to_pandas()

sf_schemas['name'] = sf_schemas['name'].str.lower()
schemas['schema'] = schemas['schema'].str.lower()

schema_validation = schemas.merge(
    sf_schemas[['name']],
    left_on='schema',
    right_on='name',
    how='left',
    indicator=True
)

schema_validation['exists_in_snowflake'] = schema_validation['_merge'] == 'both'
schema_validation = schema_validation[['schema','exists_in_snowflake']]

schema_validation

STEP 3 — Get Snowflake Tables (Only Relevant Schemas)

schema_list = "','".join(schemas['schema'])

sf_tables = session.sql(f"""
SELECT table_schema, table_name
FROM information_schema.tables
WHERE table_schema IN ('{schema_list}')
""").to_pandas()

sf_tables['table_schema'] = sf_tables['table_schema'].str.lower()
sf_tables['table_name'] = sf_tables['table_name'].str.lower()

sf_tables_h = sf_tables[sf_tables['table_name'].str.endswith('_h')]

STEP 5 — Compare Tables (Cloudera vs Snowflake)
cloudera_tables['schema'] = cloudera_tables['schema'].str.lower()
cloudera_tables['table'] = cloudera_tables['table'].str.lower()

table_validation = cloudera_tables.merge(
    sf_tables_h,
    left_on=['schema','table'],
    right_on=['table_schema','table_name'],
    how='left',
    indicator=True
)

table_validation['exists_in_snowflake'] = table_validation['_merge'] == 'both'
table_validation = table_validation[['schema','table','exists_in_snowflake']]

table_validation

sf_columns = session.sql(f"""
SELECT table_schema, table_name, column_name, data_type
FROM information_schema.columns
WHERE table_schema IN ('{schema_list}')
""").to_pandas()

sf_columns = sf_columns.apply(lambda col: col.str.lower() if col.dtype == "object" else col)



cloudera_columns = cloudera_columns.apply(lambda col: col.str.lower() if col.dtype == "object" else col)

column_compare = cloudera_columns.merge(
    sf_columns,
    left_on=['schema','table','column'],
    right_on=['table_schema','table_name','column_name'],
    how='left',
    indicator=True
)

column_compare['column_exists'] = column_compare['_merge'] == 'both'
column_compare['datatype_match'] = column_compare['data_type_x'] == column_compare['data_type_y']

column_compare = column_compare[[
    'schema','table','column','data_type_x','data_type_y',
    'column_exists','datatype_match'
]]

column_compare.rename(columns={
    'data_type_x':'cloudera_type',
    'data_type_y':'snowflake_type'
}, inplace=True)

column_compare




schema_validation.to_csv("schema_validation.csv", index=False)
table_validation.to_csv("table_validation.csv", index=False)
column_compare.to_csv("column_validation.csv", index=False)

