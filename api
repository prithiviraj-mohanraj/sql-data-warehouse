sf_tables = sf_tables.rename(columns={"name": "table"})

cloudera_h = sl1_tables[sl1_tables['table'].str.endswith('_h')]
snowflake_h = sf_tables[sf_tables['table'].str.endswith('_h')]

cloudera_total_counts = (
    sl1_tables.groupby('schema')
    .size()
    .reset_index(name='cloudera_total_tables')
)

cloudera_h_counts = (
    cloudera_h.groupby('schema')
    .size()
    .reset_index(name='cloudera_h_tables')
)

snowflake_total_counts = (
    sf_tables.groupby('schema')
    .size()
    .reset_index(name='snowflake_total_tables')
)

snowflake_h_counts = (
    snowflake_h.groupby('schema')
    .size()
    .reset_index(name='snowflake_h_tables')
)

missing_h_tables = cloudera_h.merge(
    snowflake_h,
    on=['schema','table'],
    how='left',
    indicator=True
)

missing_h_tables = missing_h_tables[
    missing_h_tables['_merge'] == 'left_only'
][['schema','table']]

missing_h_tables

missing_h_counts = (
    missing_h_tables.groupby('schema')
    .size()
    .reset_index(name='missing_h_tables')
)


schema_summary = cloudera_total_counts \
    .merge(cloudera_h_counts, on='schema', how='left') \
    .merge(snowflake_total_counts, on='schema', how='left') \
    .merge(snowflake_h_counts, on='schema', how='left') \
    .merge(missing_h_counts, on='schema', how='left')

schema_summary.fillna(0, inplace=True)

schema_summary

extra_h_tables = snowflake_h.merge(
    cloudera_h,
    on=['schema','table'],
    how='left',
    indicator=True
)

extra_h_tables = extra_h_tables[
    extra_h_tables['_merge'] == 'left_only'
][['schema','table']]

extra_h_tables

missing_h_summary = (
    missing_h_tables.groupby('schema')
    .size()
    .reset_index(name='missing_h_tables')
)

missing_h_summary

schemas_with_missing = missing_h_summary[
    missing_h_summary['missing_h_tables'] > 0
]

schemas_with_missing

total_missing = len(missing_h_tables)
schemas_impacted = missing_h_tables['schema'].nunique()

print("Total missing _h tables:", total_missing)
print("Schemas impacted:", schemas_impacted)
