oldest_dates = []

for _, row in tables_with_business_day_sf.iterrows():
    schema = row['schema']
    table = row['table']

    try:
        df = session.sql(
            f"SELECT MIN(business_day) AS oldest_business_day FROM prod.{schema}.{table}"
        ).to_pandas()

        oldest_dates.append({
            "schema": schema,
            "table": table,
            "oldest_business_day": df.iloc[0,0]
        })

    except Exception as e:
        print(f"Skipped {schema}.{table}: {e}")

oldest_business_day_df = pd.DataFrame(oldest_dates)
