nohup ./scripts/run_min_date_counts.sh > logs/min_date_counts.log 2>&1 &



import pandas as pd

cloudera_counts = pd.read_csv("min_date_counts.csv")

cloudera_counts['schema'] = cloudera_counts['schema'].str.lower()
cloudera_counts['table'] = cloudera_counts['table'].str.lower()

cloudera_counts = cloudera_counts[cloudera_counts['min_date'].notna()]


snowflake_results = []

for i,row in cloudera_counts.iterrows():

    schema = row['schema']
    table = row['table']
    column = row['date_column']
    date = row['min_date']

    query = f"""
    SELECT
        '{schema}' AS schema,
        '{table}' AS table,
        '{column}' AS date_column,
        '{date}' AS min_date,
        COUNT(*) AS record_count
    FROM prod.{schema}.{table}
    WHERE {column} = '{date}'
    """

    try:
        df = session.sql(query).to_pandas()
        snowflake_results.append(df.iloc[0].to_dict())
        print(f"{schema}.{table} completed")

    except Exception as e:
        print(f"{schema}.{table} failed")

snowflake_counts = pd.DataFrame(snowflake_results)

comparison = cloudera_counts.merge(
    snowflake_counts,
    on=['schema','table','date_column','min_date'],
    how='left',
    suffixes=('_cloudera','_snowflake')
)

comparison['match'] = (
    comparison['record_count_cloudera'] ==
    comparison['record_count_snowflake']
)

mismatch = comparison[comparison['match']==False]
mismatch

print("Total tables:", len(comparison))
print("Matched:", comparison['match'].sum())
print("Mismatch:", len(mismatch))

