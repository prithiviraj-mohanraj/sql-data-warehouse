sf_columns = session.sql(f"""
SELECT
    lower(table_schema) AS schema,
    lower(table_name) AS table,
    lower(column_name) AS column,
    lower(data_type) AS data_type,
    numeric_precision,
    numeric_scale
FROM prod.information_schema.columns
WHERE lower(table_schema) IN ('{schema_list}')
""").to_pandas()

import re

def extract_precision(dtype):
    if pd.isna(dtype):
        return None, None

    dtype = dtype.lower()

    match = re.search(r'\((\d+),\s*(\d+)\)', dtype)
    if match:
        return int(match.group(1)), int(match.group(2))

    return None, None

cloudera_columns[['precision','scale']] = cloudera_columns.apply(
    lambda row: pd.Series(extract_precision(row['data_type'])),
    axis=1
)

precision_compare = cloudera_columns.merge(
    sf_columns,
    on=['schema','table','column'],
    how='left',
    suffixes=('_cloudera','_snowflake')
)

def is_numeric(dtype):
    if pd.isna(dtype):
        return False
    return any(x in dtype for x in ['decimal','numeric','number','int','bigint'])
def precision_status(row):

    if not is_numeric(row['data_type_cloudera']):
        return "NOT_NUMERIC"

    # If Snowflake missing
    if pd.isna(row['data_type_snowflake']):
        return "MISSING_IN_SNOWFLAKE"

    # Compare precision
    if row['precision'] == row['numeric_precision'] and \
       row['scale'] == row['numeric_scale']:
        return "MATCH"

    return "MISMATCH"

precision_compare['precision_status'] = precision_compare.apply(
    precision_status,
    axis=1
)

precision_mismatch = precision_compare[
    precision_compare['precision_status'] == "MISMATCH"
]

summary_precision = (
    precision_mismatch.groupby('schema')
    .size()
    .reset_index(name='precision_mismatch_count')
)

