

import pandas as pd

schemas = pd.read_csv("schemas.txt", header=None, names=["schema"])
cloudera_tables = pd.read_csv("schemas_tables.csv")
cloudera_columns = pd.read_csv("table_columns.csv")

# normalize
for df in [schemas, cloudera_tables, cloudera_columns]:
    for col in df.columns:
        if df[col].dtype == "object":
            df[col] = df[col].str.lower()
sf_schemas = session.sql("SHOW SCHEMAS").to_pandas()
sf_schemas['name'] = sf_schemas['name'].str.lower()

schema_validation = schemas.merge(
    sf_schemas[['name']],
    left_on='schema',
    right_on='name',
    how='left',
    indicator=True
)

schema_validation['exists_in_snowflake'] = schema_validation['_merge'] == 'both'

schema_validation = schema_validation[['schema','exists_in_snowflake']]
schema_validation
sf_tables_list = []

for schema in schemas['schema']:
    try:
        df = session.sql(f"SHOW TABLES IN SCHEMA prod.{schema}").to_pandas()
        df['schema'] = schema
        sf_tables_list.append(df[['schema','name']])
    except:
        pass

sf_tables = pd.concat(sf_tables_list, ignore_index=True)
sf_tables['name'] = sf_tables['name'].str.lower()

cloudera_table_counts = cloudera_tables.groupby('schema').size().reset_index(name='cloudera_table_count')

sf_tables_h = sf_tables[sf_tables['name'].str.endswith('_h')]

sf_table_counts = sf_tables_h.groupby('schema').size().reset_index(name='snowflake_table_count')

matching_tables = cloudera_tables.merge(
    sf_tables_h,
    left_on=['schema','table'],
    right_on=['schema','name'],
    how='inner'
)

matching_counts = matching_tables.groupby('schema').size().reset_index(name='matching_tables')

table_summary = cloudera_table_counts.merge(sf_table_counts, on='schema', how='left')
table_summary = table_summary.merge(matching_counts, on='schema', how='left')

table_summary.fillna(0, inplace=True)
table_summary

cloudera_col_counts = cloudera_columns.groupby(['schema','table']).size().reset_index(name='cloudera_column_count')

sf_column_list = []

for _, row in cloudera_tables.iterrows():
    schema = row['schema']
    table = row['table']
    try:
        df = session.sql(f"SHOW COLUMNS IN TABLE prod.{schema}.{table}").to_pandas()
        df['schema'] = schema
        df['table'] = table
        sf_column_list.append(df[['schema','table','column_name']])
    except:
        pass

sf_columns = pd.concat(sf_column_list, ignore_index=True)
sf_columns = sf_columns.apply(lambda col: col.str.lower() if col.dtype == "object" else col)

sf_col_counts = sf_columns.groupby(['schema','table']).size().reset_index(name='snowflake_column_count')

column_comparison = cloudera_col_counts.merge(
    sf_col_counts,
    on=['schema','table'],
    how='left'
)

column_comparison['column_count_match'] = (
    column_comparison['cloudera_column_count'] == column_comparison['snowflake_column_count']
)

column_comparison.fillna(0, inplace=True)
column_comparison

