scripts/filter_businessdate_tables.py
import pandas as pd

INPUT="../input/sl1_table_columns.psv"

df = pd.read_csv(INPUT, sep="|")

df.columns=["schema","table","column","datatype"]

df['schema']=df['schema'].str.lower()
df['table']=df['table'].str.lower()
df['column']=df['column'].str.lower()

# only _h and _t2
df = df[df['table'].str.endswith(('_h','_t2'))]

kafka_tables = df[df['column']=="kafka_process_dt"][["schema","table"]].drop_duplicates()
ods_tables   = df[df['column']=="ods_business_day"][["schema","table"]].drop_duplicates()

kafka_tables["date_column"]="kafka_process_dt"
ods_tables["date_column"]="ods_business_day"

# remove duplicates where kafka exists
ods_tables = ods_tables.merge(
    kafka_tables[["schema","table"]],
    on=["schema","table"],
    how="left",
    indicator=True
)

ods_tables = ods_tables[ods_tables["_merge"]=="left_only"][["schema","table","date_column"]]

valid_tables = pd.concat([kafka_tables,ods_tables])

all_tables = df[["schema","table"]].drop_duplicates()

excluded_tables = all_tables.merge(
    valid_tables[["schema","table"]],
    on=["schema","table"],
    how="left",
    indicator=True
)

excluded_tables = excluded_tables[excluded_tables["_merge"]=="left_only"][["schema","table"]]

valid_tables.to_csv("../intermediate/tables_with_businessdate.csv",index=False)
excluded_tables.to_csv("../intermediate/tables_without_businessdate.csv",index=False)

print("tables with date column:",len(valid_tables))
print("tables excluded:",len(excluded_tables))

scripts/generate_min_date_sql.sh
#!/bin/bash

INPUT="../intermediate/tables_with_businessdate.csv"
OUT="../logs/min_date_queries.sql"

> $OUT

tail -n +2 $INPUT | while IFS=',' read SCHEMA TABLE COL
do
echo "SELECT '${SCHEMA}','${TABLE}','${COL}',MIN(${COL}) FROM ${SCHEMA}.${TABLE};" >> $OUT
done

echo "SQL generated: $OUT"

