scripts/identify_numeric_columns.sh

#!/bin/bash

COL_FILE="../output/table_columns.csv"
OUT="../logs/numeric_columns.csv"

echo "schema,table,column" > $OUT

grep -Ei ',(int|bigint|double|float|decimal)' $COL_FILE | cut -d',' -f1,2,3 >> $OUT

echo "Numeric columns → $OUT"

scripts/generate_sum_sql.sh
#!/bin/bash

INPUT="../logs/numeric_columns.csv"
SQL_FILE="../logs/sum_queries.sql"

> $SQL_FILE

tail -n +2 $INPUT | while IFS=',' read SCHEMA TABLE COLUMN
do
    echo "SELECT '${SCHEMA}','${TABLE}','${COLUMN}', SUM(${COLUMN}) 
          FROM ${SCHEMA}.${TABLE};" >> $SQL_FILE
done

echo "SUM queries generated → $SQL_FILE"

