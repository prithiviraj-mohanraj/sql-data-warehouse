import re

def hive_base_type(dtype):

    if pd.isna(dtype):
        return None

    return re.split(r'\(', str(dtype).lower())[0]

cloudera_cols['base_type'] = cloudera_cols['datatype'].apply(hive_base_type)

sf_columns['base_type'] = sf_columns['datatype'].str.lower()

mapping = pd.read_csv("datatype_mapping.csv")

mapping['hive_type'] = mapping['hive_type'].str.lower()
mapping['snowflake_type'] = mapping['snowflake_type'].str.lower()

cloudera_cols = cloudera_cols.merge(
    mapping,
    left_on='base_type',
    right_on='hive_type',
    how='left'
)

cloudera_cols.rename(
    columns={'snowflake_type':'expected_sf_type'},
    inplace=True
)
datatype_compare = cloudera_cols.merge(
    sf_columns,
    on=['schema','table','column'],
    suffixes=('_hive','_snowflake')
)
datatype_compare['datatype_match'] = (
    datatype_compare['expected_sf_type'] ==
    datatype_compare['base_type_snowflake']
)

datatype_mismatch = datatype_compare[
    datatype_compare['datatype_match'] == False
][['schema','table','column','base_type_hive','base_type_snowflake']]

datatype_compare['datatype_match'].value_counts()
