import re

def normalize_type(dtype):
    if pd.isna(dtype):
        return None

    dtype = dtype.lower()

    # remove precision: number(38,0) → number
    base = re.split(r'\(|\s', dtype)[0]

    mapping = {
        # STRING
        "string": "string",
        "varchar": "string",
        "char": "string",
        "text": "string",

        # NUMERIC
        "int": "number",
        "bigint": "number",
        "smallint": "number",
        "tinyint": "number",
        "decimal": "number",
        "numeric": "number",
        "number": "number",

        # FLOAT
        "double": "float",
        "float": "float",

        # DATE/TIME
        "date": "date",
        "timestamp": "timestamp",
        "timestamp_ntz": "timestamp",
        "timestamp_ltz": "timestamp",
        "timestamp_tz": "timestamp",

        # BOOLEAN
        "boolean": "boolean",
        "bool": "boolean",

        # COMPLEX
        "array": "array",
        "variant": "variant",
    }

    return mapping.get(base, base)


cloudera_columns['normalized_type'] = cloudera_columns['data_type'].apply(normalize_type)
