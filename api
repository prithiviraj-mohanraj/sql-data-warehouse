
sf_columns = session.sql(f"""
SELECT
    lower(table_schema) as schema,
    lower(table_name) as table,
    lower(column_name) as column,
    lower(data_type) as data_type,
    numeric_precision,
    numeric_scale,
    character_maximum_length
FROM prod.information_schema.columns
WHERE lower(table_schema) IN ('{schema_list}')
""").to_pandas()

import re

def extract_precision(dtype):

    dtype = str(dtype).lower()

    match = re.search(r'\((\d+),?(\d+)?\)', dtype)

    if match:
        precision = int(match.group(1))
        scale = int(match.group(2)) if match.group(2) else 0
        return precision, scale

    return None, None

cloudera_columns[['precision','scale']] = cloudera_columns['data_type'].apply(
    lambda x: pd.Series(extract_precision(x))
)

def normalize_type(dtype):

    dtype = str(dtype).lower()
    base = dtype.split("(")[0]

    mapping = {
        "string": "varchar",
        "varchar": "varchar",
        "char": "varchar",

        "int": "number",
        "bigint": "number",
        "smallint": "number",
        "tinyint": "number",

        "decimal": "number",
        "numeric": "number",
        "number": "number",

        "float": "float",
        "double": "float",

        "timestamp": "timestamp_ntz",
        "date": "date",

        "boolean": "boolean"
    }

    return mapping.get(base, base)

cloudera_columns['normalized_type'] = cloudera_columns['data_type'].apply(normalize_type)
sf_columns['normalized_type'] = sf_columns['data_type'].apply(normalize_type)

precision_compare = cloudera_columns.merge(
    sf_columns,
    on=['schema','table','column'],
    how='left',
    suffixes=('_cloudera','_snowflake')
)

def validate_precision(row):

    # datatype mismatch
    if row['normalized_type_cloudera'] != row['normalized_type_snowflake']:
        return "DATATYPE_MISMATCH"

    # if cloudera has no precision
    if pd.isna(row['precision']):
        return "MATCH"

    sf_precision = row['numeric_precision']
    sf_scale = row['numeric_scale']

    if sf_precision == row['precision'] and sf_scale == row['scale']:
        return "MATCH"

    if sf_precision > row['precision']:
        return "PRECISION_TOO_HIGH"

    return "PRECISION_MISMATCH"

precision_compare['precision_status'] = precision_compare.apply(
    validate_precision, axis=1
)

precision_issues = precision_compare[
    precision_compare['precision_status'] != "MATCH"
]

precision_summary = precision_compare['precision_status'].value_counts()

