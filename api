import pandas as pd

tables = pd.read_csv("all_tables.csv")

columns = pd.read_csv(
    "snowflake_columns.psv",
    sep="|",
    names=["schema","table","column","datatype"]
)

tables['schema'] = tables['schema'].str.lower()
tables['table'] = tables['table'].str.lower()

columns['schema'] = columns['schema'].str.lower()
columns['table'] = columns['table'].str.lower()

column_tables = columns[['schema','table']].drop_duplicates()

missing_column_tables = tables.merge(
    column_tables,
    on=['schema','table'],
    how='left',
    indicator=True
)

missing_column_tables = missing_column_tables[
    missing_column_tables['_merge']=='left_only'
][['schema','table']]
print("Total tables:", len(tables))
print("Tables with columns extracted:", len(column_tables))
print("Tables missing column extraction:", len(missing_column_tables))
