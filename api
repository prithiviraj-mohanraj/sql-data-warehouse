scripts/generate_counts_sql.sh
#!/bin/bash

TABLES="../logs/tables_with_business_day.csv"
DATES_FILE="../input/business_days.txt"
SQL_FILE="../logs/count_queries.sql"

> $SQL_FILE

DATES=$(paste -sd"," $DATES_FILE | sed "s/,/','/g")

tail -n +2 $TABLES | while IFS=',' read SCHEMA TABLE
do
    echo "SELECT '${SCHEMA}','${TABLE}', business_day, COUNT(*) 
          FROM ${SCHEMA}.${TABLE}
          WHERE business_day IN ('$DATES')
          GROUP BY business_day;" >> $SQL_FILE
done

echo "Count queries generated → $SQL_FILE"

