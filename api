#!/bin/bash

INPUT="../input/cloudera_oldest_business_day.csv"
SQL_FILE="../logs/oldest_day_counts.sql"

> $SQL_FILE

tail -n +2 $INPUT | while IFS=',' read SCHEMA_TABLE OLDEST
do
    # Skip null or empty dates
    if [[ -z "$OLDEST" || "$OLDEST" == "NULL" ]]; then
        echo "Skipping $SCHEMA_TABLE due to NULL oldest date"
        continue
    fi

    SCHEMA=$(echo $SCHEMA_TABLE | cut -d'.' -f1)
    TABLE=$(echo $SCHEMA_TABLE | cut -d'.' -f2)

    echo "SELECT '${SCHEMA}','${TABLE}','${OLDEST}', COUNT(*) 
          FROM ${SCHEMA}.${TABLE}
          WHERE business_day='${OLDEST}';" >> $SQL_FILE

done

echo "SQL generated → $SQL_FILE"


