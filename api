common_schemas = schemas.merge(
    sf_schemas,
    on="schema",
    how="inner"
)
cloudera_tables_filtered = tables[
    tables["schema"].isin(common_schemas["schema"])
]

sf_tables_filtered = sf_tables[
    sf_tables["schema"].isin(common_schemas["schema"])
]

cloudera_tables_filtered = cloudera_tables_filtered[
    cloudera_tables_filtered["table"].str.endswith(("_h","_t2"))
]

sf_tables_filtered = sf_tables_filtered[
    sf_tables_filtered["table"].str.endswith(("_h","_t2"))
]

missing_tables = cloudera_tables_filtered.merge(
    sf_tables_filtered,
    on=["schema","table"],
    how="left",
    indicator=True
)

missing_tables = missing_tables[
    missing_tables["_merge"]=="left_only"
][["schema","table"]]

extra_tables = sf_tables_filtered.merge(
    cloudera_tables_filtered,
    on=["schema","table"],
    how="left",
    indicator=True
)

extra_tables = extra_tables[
    extra_tables["_merge"]=="left_only"
][["schema","table"]]
