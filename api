#!/bin/bash

INPUT_FILE="input_min_dates.csv"
OUTPUT_FILE="cloudera_min_date_counts.csv"
FAILED_FILE="failed_tables.csv"

IMPALA_HOST="your-host"

# headers
echo "schema,table,column,mindate,count" > $OUTPUT_FILE
echo "schema,table,column,mindate" > $FAILED_FILE

tail -n +2 $INPUT_FILE | while IFS=',' read SCHEMA TABLE COL DATE
do

# skip empty
if [[ -z "$SCHEMA" || -z "$TABLE" || -z "$COL" || -z "$DATE" ]]; then
    echo "$SCHEMA,$TABLE,$COL,$DATE" >> $FAILED_FILE
    continue
fi

QUERY="SELECT COUNT(${COL}) FROM ${SCHEMA}.${TABLE} WHERE ${COL}='${DATE}';"

RESULT=$(impala-shell -k -i $IMPALA_HOST -B -q "$QUERY" 2>/dev/null)

# get last line (actual result)
COUNT=$(echo "$RESULT" | tail -n 1)

# check error or empty
if [[ -z "$COUNT" || "$COUNT" == *"ERROR"* ]]; then
    echo "$SCHEMA,$TABLE,$COL,$DATE" >> $FAILED_FILE
    echo "$SCHEMA.$TABLE failed"
else
    echo "$SCHEMA,$TABLE,$COL,$DATE,$COUNT" >> $OUTPUT_FILE
    echo "$SCHEMA.$TABLE done"
fi

done

echo "Completed → $OUTPUT_FILE"
echo "Failed tables → $FAILED_FILE"



cloudera_min_date_count_retry.sh



nohup bash cloudera_min_date_count_retry.sh > logs/min_count_retry.log 2>&1 &

tail -f logs/min_count_retry.log
