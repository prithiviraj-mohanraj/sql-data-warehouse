#!/bin/bash

SQL="../logs/min_date_queries.sql"
RAW="../logs/min_dates_raw.txt"
OUT="../output/min_business_dates.csv"

echo "schema,table,date_column,min_date" > $OUT

impala-shell -k -i your-host -f $SQL -B > $RAW

awk -F'\t' 'NF>=4 {print $1","$2","$3","$4}' $RAW >> $OUT

echo "completed"


nohup ./scripts/run_min_date.sh > logs/min_date_run.log 2>&1 &


