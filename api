    snowflake_counts_df,
    on=['schema','table','business_day'],
    how='outer',
    suffixes=('_cloudera','_snowflake')
)

count_compare['match'] = (
    count_compare['record_count_cloudera'] ==
    count_compare['record_count_snowflake']
)

count_compare

