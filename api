scripts/find_missing_column_tables.sh
#!/bin/bash

TABLES="../input/tables_sl1.csv"
COLS="../input/columns_sl1.psv"

OUT="../intermediate/tables_missing_columns.csv"

cut -d',' -f1,2 $TABLES | tail -n +2 | sort > /tmp/all_tables.txt
cut -d'|' -f1,2 $COLS | sort | uniq > /tmp/column_tables.txt

comm -23 /tmp/all_tables.txt /tmp/column_tables.txt > $OUT

echo "Missing column tables saved → $OUT"

scripts/extract_missing_columns.sh
#!/bin/bash

INPUT="../intermediate/tables_missing_columns.csv"
OUT="../input/columns_sl1.psv"

tail -n +1 $INPUT | while IFS=',' read SCHEMA TABLE
do

impala-shell -k -i your-host -B -q "DESCRIBE ${SCHEMA}.${TABLE}" |
awk -v s=$SCHEMA -v t=$TABLE '
NF>=2 && $1!="#" {
print s "|" t "|" $1 "|" $2
}' >> $OUT

echo "$SCHEMA.$TABLE extracted"

done

