scripts/generate_min_date_count_sql.sh
#!/bin/bash

INPUT="../output/min_business_dates.csv"
SQL="../logs/min_date_count_queries.sql"

> $SQL

tail -n +2 $INPUT | while IFS=',' read SCHEMA TABLE COL DATE
do

echo "SELECT '${SCHEMA}','${TABLE}','${COL}','${DATE}',COUNT(*) 
FROM ${SCHEMA}.${TABLE} 
WHERE ${COL}='${DATE}';" >> $SQL

done

echo "SQL created → $SQL"


