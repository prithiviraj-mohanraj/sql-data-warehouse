#!/bin/bash

BATCH_DIR="../logs/describe_batches"
RAW_OUT_DIR="../logs/raw_describe"

mkdir -p $RAW_OUT_DIR

for SQL_FILE in $BATCH_DIR/*.sql
do
    BASENAME=$(basename $SQL_FILE .sql)
    OUT_FILE="$RAW_OUT_DIR/${BASENAME}.txt"

    echo "Running batch $BASENAME"

    impala-shell -k -i your-host -f $SQL_FILE -B > $OUT_FILE

    sleep 2   # prevent coordinator overload
done

echo "All batches completed."


