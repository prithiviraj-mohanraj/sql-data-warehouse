import pandas as pd

cloudera_df = pd.read_csv("cloudera_min_date_counts.csv")
snowflake_df = pd.read_csv("snowflake_min_date_counts.csv")


for df in [cloudera_df, snowflake_df]:
    df['schema'] = df['schema'].str.lower()
    df['table'] = df['table'].str.lower()
    df['date_column'] = df['date_column'].str.lower()

cloudera_df = cloudera_df.rename(columns={
    "min_date": "min_date_cloudera",
    "record_count": "count_cloudera"
})

snowflake_df = snowflake_df.rename(columns={
    "min_date": "min_date_snowflake",
    "record_count": "count_snowflake"
})

compare_df = cloudera_df.merge(
    snowflake_df,
    on=['schema','table','date_column'],
    how='outer'
)

compare_df['date_match'] = (
    compare_df['min_date_cloudera'] ==
    compare_df['min_date_snowflake']
)

compare_df['count_match'] = (
    compare_df['count_cloudera'] ==
    compare_df['count_snowflake']
)

def final_status(row):

    if pd.isna(row['min_date_snowflake']):
        return "MISSING_IN_SNOWFLAKE"

    if pd.isna(row['min_date_cloudera']):
        return "EXTRA_IN_SNOWFLAKE"

    if not row['date_match']:
        return "MIN_DATE_MISMATCH"

    if not row['count_match']:
        return "COUNT_MISMATCH"

    return "MATCH"


compare_df['status'] = compare_df.apply(final_status, axis=1)


mismatch_df = compare_df[
    compare_df['status'] != "MATCH"
]
compare_df['status'].value_counts()
