#!/bin/bash

INPUT="../output/min_business_dates.csv"

SQL="../logs/min_date_count_queries.sql"
NULL_TABLES="../output/tables_with_null_mindate.csv"

> $SQL
echo "schema,table,date_column,min_date" > $NULL_TABLES

tail -n +2 $INPUT | while IFS=',' read SCHEMA TABLE COL DATE
do

# detect null / empty
if [[ -z "$DATE" || "$DATE" == "NULL" ]]; then
    echo "$SCHEMA,$TABLE,$COL,$DATE" >> $NULL_TABLES
    continue
fi

echo "SELECT '${SCHEMA}','${TABLE}','${COL}','${DATE}',COUNT(*) 
FROM ${SCHEMA}.${TABLE} 
WHERE ${COL}='${DATE}';" >> $SQL

done

echo "SQL generated: $SQL"
echo "Null date tables saved: $NULL_TABLES"

