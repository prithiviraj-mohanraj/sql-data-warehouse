cluster_results = []

for _,row in tables_with_date.iterrows():

    schema = row['schema']
    table = row['table']
    column = row['date_column']

    query = f"""
    SELECT
    PARSE_JSON(SYSTEM$CLUSTERING_INFORMATION(
        'prod.{schema}.{table}',
        '({column})'
    )) AS cluster_info
    """

    try:
        df = session.sql(query).to_pandas()

        j = df['cluster_info'][0]

        cluster_results.append({
            "schema":schema,
            "table":table,
            "column":column,
            "total_partition_count": j.get("total_partition_count"),
            "constant_partition_count": j.get("constant_partition_count"),
            "average_depth": j.get("average_depth"),
            "average_overlaps": j.get("average_overlaps")
        })

        print(f"{schema}.{table} done")

    except Exception as e:
        print(f"{schema}.{table} failed")

cluster_df = pd.DataFrame(cluster_results)

cluster_df["constant_ratio"] = (
    cluster_df["constant_partition_count"] /
    cluster_df["total_partition_count"]
)

def table_health(row):

    if row['average_depth'] > 5:
        return "UNHEALTHY"

    if row['average_overlaps'] > 5:
        return "UNHEALTHY"

    if row['constant_ratio'] < 0.5:
        return "UNHEALTHY"

    return "HEALTHY"


cluster_df["table_health"] = cluster_df.apply(table_health,axis=1)

unhealthy_tables = cluster_df[
