datatype_compare = cloudera_columns.merge(
    sf_columns,
    on=['schema','table','column'],
    how='left',
    suffixes=('_cloudera','_snowflake')
)

def classify_datatype(row):
    if pd.isna(row['normalized_type_snowflake']):
        return "MISSING_IN_SNOWFLAKE"

    if row['normalized_type_cloudera'] == row['normalized_type_snowflake']:
        return "MATCH"

    return "MISMATCH"

datatype_compare['datatype_status'] = datatype_compare.apply(classify_datatype, axis=1)


