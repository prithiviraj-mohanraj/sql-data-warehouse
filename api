#!/bin/bash

INPUT="../input/sl1_tables.csv"
BATCH_SIZE=100
OUT_DIR="../logs/describe_batches"

mkdir -p $OUT_DIR

tail -n +2 $INPUT > ../logs/tables_list.txt

split -l $BATCH_SIZE ../logs/tables_list.txt $OUT_DIR/batch_

for file in $OUT_DIR/batch_*
do
    SQL_FILE="${file}.sql"
    > $SQL_FILE

    while IFS=',' read SCHEMA TABLE
    do
        echo "SELECT 'START:${SCHEMA}.${TABLE}';" >> $SQL_FILE
        echo "DESCRIBE ${SCHEMA}.${TABLE};" >> $SQL_FILE
        echo "SELECT 'END:${SCHEMA}.${TABLE}';" >> $SQL_FILE
    done < $file
done

echo "Batch SQL files created in $OUT_DIR"


