sf_columns_list = []

for _, row in cloudera_tables.iterrows():
    schema = row['schema']
    table = row['table']

    try:
        df = session.sql(f"SHOW COLUMNS IN TABLE prod.{schema}.{table}").to_pandas()

        df['schema'] = schema
        df['table'] = table

        # IMPORTANT: use 'type' column for datatype
        sf_columns_list.append(df[['schema','table','column_name','type']])

    except Exception as e:
        print(f"Skipped {schema}.{table}: {e}")

sf_columns = pd.concat(sf_columns_list, ignore_index=True)

# rename columns
sf_columns.rename(columns={
    "column_name": "column",
    "type": "data_type"
}, inplace=True)

# normalize case
sf_columns = sf_columns.apply(lambda col: col.str.lower() if col.dtype=="object" else col)

sf_columns.head()

def normalize_type(dtype: str) -> str:
    if dtype is None:
        return None

    dtype = dtype.lower()

    # remove precision
    base = dtype.split("(")[0]

    mapping = {
        # strings
        "string": "string",
        "varchar": "string",
        "char": "string",
        "text": "string",

        # numbers
        "int": "number",
        "bigint": "number",
        "smallint": "number",
        "tinyint": "number",
        "number": "number",

        # decimals
        "decimal": "decimal",
        "numeric": "decimal",

        # floats
        "double": "float",
        "float": "float",

        # dates
        "date": "date",
        "timestamp": "timestamp",
        "timestamp_ntz": "timestamp",
        "timestamp_ltz": "timestamp",

        # boolean
        "boolean": "boolean",
    }

    return mapping.get(base, base)



cloudera_columns['normalized_type'] = cloudera_columns['data_type'].apply(normalize_type)
sf_columns['normalized_type'] = sf_columns['data_type'].apply(normalize_type)



datatype_compare = cloudera_columns.merge(
    sf_columns,
    on=['schema','table','column'],
    how='left',
    suffixes=('_cloudera','_snowflake')
)

def classify_datatype(row):
    if pd.isna(row['normalized_type_snowflake']):
        return "MISSING_IN_SNOWFLAKE"

    if row['normalized_type_cloudera'] == row['normalized_type_snowflake']:
        return "MATCH"

    # compatible cases
    compatible_pairs = [
        ("decimal", "number"),
        ("number", "decimal"),
    ]

    if (row['normalized_type_cloudera'], row['normalized_type_snowflake']) in compatible_pairs:
        return "COMPATIBLE"

    return "MISMATCH"

datatype_compare['datatype_status'] = datatype_compare.apply(classify_datatype, axis=1)
