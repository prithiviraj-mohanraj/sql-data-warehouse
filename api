import pandas as pd

tables_df = pd.read_csv("min_date_counts.csv")

tables_df['schema'] = tables_df['schema'].str.lower()
tables_df['table'] = tables_df['table'].str.lower()
tables_df['date_column'] = tables_df['date_column'].str.lower()

tables_df.head()

cluster_results = []

for _,row in tables_df.iterrows():

    schema = row['schema']
    table = row['table']
    column = row['date_column']

    query = f"""
    SELECT PARSE_JSON(
        SYSTEM$CLUSTERING_INFORMATION(
            'PROD.{schema}.{table}',
            '({column})'
        )
    ) AS info
    """

    try:
        df = session.sql(query).to_pandas()
        j = df['INFO'][0]

        cluster_results.append({
            "schema":schema,
            "table":table,
            "column":column,
            "total_partition_count": j.get("total_partition_count"),
            "constant_partition_count": j.get("constant_partition_count"),
            "average_depth": j.get("average_depth"),
            "average_overlaps": j.get("average_overlaps")
        })

        print(f"{schema}.{table} completed")

    except Exception as e:
        print(f"{schema}.{table} failed")

cluster_df = pd.DataFrame(cluster_results)

cluster_df.head()

cluster_df["constant_ratio"] = (
    cluster_df["constant_partition_count"] /
    cluster_df["total_partition_count"]
)

def check_health(row):

    if row['average_depth'] > 5:
        return "UNHEALTHY"

    if row['average_overlaps'] > 5:
        return "UNHEALTHY"

    if row['constant_ratio'] < 0.5:
        return "UNHEALTHY"

    return "HEALTHY"


cluster_df["table_health"] = cluster_df.apply(check_health, axis=1)

unhealthy_tables = cluster_df[
    cluster_df["table_health"] == "UNHEALTHY"
]

unhealthy_tables

