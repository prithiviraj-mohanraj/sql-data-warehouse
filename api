def normalize_type(dtype: str) -> str:
    if dtype is None:
        return None

    dtype = dtype.lower()

    # remove precision
    base = dtype.split("(")[0]

    mapping = {
        "string": "string",
        "varchar": "string",
        "char": "string",
        "text": "string",

        "int": "number",
        "bigint": "number",
        "smallint": "number",
        "tinyint": "number",
        "number": "number",

        "double": "float",
        "float": "float",

        "decimal": "decimal",
        "numeric": "decimal",

        "boolean": "boolean",
        "date": "date",
        "timestamp": "timestamp",
        "timestamp_ntz": "timestamp",
        "timestamp_ltz": "timestamp",
    }

    return mapping.get(base, base)


