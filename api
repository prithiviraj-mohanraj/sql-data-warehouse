#!/bin/bash

SQL="../logs/min_date_count_queries.sql"
RAW="../logs/min_date_counts_raw.txt"
OUT="../output/min_date_counts.csv"

echo "schema,table,date_column,min_date,record_count" > $OUT

impala-shell -k -i your-host -f $SQL -B > $RAW

