valid_oldest = cloudera_oldest.dropna(subset=['oldest_business_day'])

snowflake_counts = []

for _, row in valid_oldest.iterrows():
    schema = row['schema']
    table = row['table']
    oldest = row['oldest_business_day']

    try:
        df = session.sql(
            f"""
            SELECT COUNT(*) AS record_count
            FROM prod.{schema}.{table}
            WHERE business_day = '{oldest}'
            """
        ).to_pandas()

        snowflake_counts.append({
            "schema": schema,
            "table": table,
            "business_day": oldest,
            "record_count": df.iloc[0,0]
        })

    except Exception as e:
        print(f"Skipped {schema}.{table}: {e}")

snowflake_counts_df = pd.DataFrame(snowflake_counts)
snowflake_counts_df

cloudera_counts = pd.read_csv("cloudera_oldest_day_counts.csv")

